def robot(player_board):
    '''
Description:
             lets the robot choose spots to aim for player's ships
Args:
        player_board (list) - where robot is shooting

Returns:
         True, meaning the robot has hit, or False, meaning the robot has missed
    
    
    '''
    while True:
        row = random.randint(0,4) #assigns random row for robot to guess ships
        column = random.randint(0,4) #assigns random column for robot to guess ships
        if player_board [row][column] == '🚢':
            player_board[row][column] = '💥'
            print ('The robot hit a battleship')
            return True #means the robot hit ship
        elif player_board [row][column] == 'X':
            player_board[row][column] = '🌊' #what is replaced for blank 
            print ('The robot has missed')
            return False  #means the robot missed

        

def sound_effects(sound):
    '''
Description:
             initializes pygame for sound features
Args:
        sound, (sound) selects noise to use
Returns:
            different sounds based on scenario
    '''
    pygame.init() #initializes pygame 
    pygame.mixer.init() #intializes the mixer

    pygame.mixer.music.load(f"{sound}") #loads sound
    pygame.mixer.music.set_volume(0.8) #sets volume of sound
    pygame.mixer.music.play() #plays sound

    while pygame.mixer.music.get_busy(): #waits 3 secs for sound
        pygame.time.Clock().tick(3)



