def ai_dot_selection(number_of_ships, rows, columns):
    '''
Description:
             chooses where on the board ships will be placed 
Args:
         number_of_ships (int)  rows (list) (columns) list
Returns:
         randomly selected ship locations on board and adds them to list of rows and columns 
    '''

    count = number_of_ships
    positions = []
    while count > 0:
        battleship_rows = random.randint(0,4) #random spots where battleships placed in rows 
        battleship_columns = random.randint(0,4) #random spots in columns where battleships are placed
        if ai_board [battleship_rows][battleship_columns] == 'X':
            rows.append(battleship_rows) #adds to list in main 
            columns.append(battleship_columns)
            count = count -1
    for i in range(len(rows)):
        positions.append([rows[i], columns[i]]) #random spots robot chooses is added to positions list
    return positions

